# ───────────────────────────────────────────────
# آرکان — متغیرهای محیطی
# این فایل را به .env.local کپی کنید و مقادیر را پر کنید.
# ───────────────────────────────────────────────

# Supabase (برای ذخیره‌ی درخواست‌های مشاوره در جدول leads)
# از داشبورد پروژه: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# پنل مدیریت (/admin) — برای دسترسی مدیر به درخواست‌ها
# ADMIN_PASSWORD: رمزی که مدیر با آن وارد /admin می‌شود (آن را تغییر دهید).
# ADMIN_SESSION_SECRET: یک رشته‌ی تصادفی برای امضای کوکی نشست؛ با این دستور بسازید:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=یک-رمز-قوی-بگذارید
ADMIN_SESSION_SECRET=یک-رشته-تصادفی-بلند

# اطلاع‌رسانی ایمیل (اختیاری) — برای فعال‌سازی، قلاب مربوطه را در
# src/app/actions.ts از کامنت خارج کنید.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# نکته: تا زمانی که کلیدهای Supabase تنظیم نشده باشند، فرم در حالت
# «فالبک» کار می‌کند و درخواست‌ها در کنسول سرور لاگ می‌شوند.
